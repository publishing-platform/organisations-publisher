<div class="mb-3">
  <%= f.label :name, "Name", class: "form-label" %>
  <%= f.text_field :name, class: "form-control", aria: { describedby: (resource.errors.has_key?(:name) ? "name-errors" : nil) } %>    
  <%= render "components/errors", {
    attribute: :name,
    resource:
  } %>
</div>

<div class="mb-3">
  <%= f.label :abbreviation, "Abbreviation", class: "form-label" %>
  <%= f.text_field :abbreviation, class: "form-control", aria: { describedby: (resource.errors.has_key?(:abbreviation) ? "abbreviation-errors" : nil) } %>    
  <%= render "components/errors", {
    attribute: :abbreviation,
    resource:
  } %>
</div>

<div class="mb-3">
  <%= f.label :organisation_type_key, "Organisation type", class: "form-label" %>     
  <%= f.select :organisation_type_key, 
      options_for_select(OrganisationType.all.collect{ |t| [t.name, t.key]}, f.object.organisation_type_key), 
      {}, 
      class: "form-control",
      aria: { describedby: (resource.errors.has_key?(:organisation_type_key) ? "organisation_type_key-errors" : nil) } 
  %>
  <%= render "components/errors", {
    attribute: :organisation_type_key,
    resource:
  } %>  
</div>  

<%= field_set_tag "Status", aria: { describedby: (resource.errors.has_key?(:status)) ? "status-errors" : nil }, class: "mb-3" do %>
  <%= tag.div class: "form-check #{(resource.errors.has_key?(:status) ? "is-invalid" : nil)}"  do %>
    <%= f.radio_button :status, "live", class: "form-check-input #{(resource.errors.has_key?(:status) ? "is-invalid" : nil)}"  %>
    <%= f.label "status_live", "Live", class: "form-check-label" %>
  <% end %>
  <%= tag.div class: "form-check #{(resource.errors.has_key?(:status) ? "is-invalid" : nil)}"  do %>
    <%= f.radio_button :status, "closed", class: "form-check-input #{(resource.errors.has_key?(:status) ? "is-invalid" : nil)}"  %>
    <%= f.label "status_closed", "Closed", class: "form-check-label" %>
  <% end %>  

  <%= render "components/errors", {
    attribute: :status,
    resource:    
  } %>  

<% end %>